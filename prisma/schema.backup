model WebsiteSettings {
  id Int @id @default(1)

  siteName String @default("ChaYanLongGong")
  logo String @default("")

  whatsapp String @default("")
  telegram String @default("")
  signal String @default("")
  line String @default("")
  wechat String @default("")

  email String @default("")

  enableWhatsApp Boolean @default(true)
  enableTelegram Boolean @default(true)
  enableSignal Boolean @default(true)
  enableLine Boolean @default(false)
  enableWechat Boolean @default(false)
  enableFeedbackEmail Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}